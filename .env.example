# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI — any OpenAI-compatible provider (used for statement parsing + insights)
# Free option (recommended): Groq → https://console.groq.com/keys
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=your-groq-key
AI_MODEL=llama-3.3-70b-versatile
# To use OpenAI instead: leave AI_BASE_URL unset (defaults to OpenAI),
# set AI_API_KEY=sk-... and AI_MODEL=gpt-4o-mini
# To use Google Gemini (also free): AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   AI_API_KEY=<aistudio key>  AI_MODEL=gemini-2.0-flash

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
